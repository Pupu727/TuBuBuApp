@import './modal-layout.wxss';

/* 编辑弹窗内表单与新增页保持一致 */
.edit-modal .edit-scroll .edit-form {
  width: 100%;
  box-sizing: border-box;
}

.edit-modal .edit-form-row {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: stretch;
}

.edit-modal .edit-form .edit-field-head .edit-label {
  display: inline;
}

.edit-form {
  display: flex;
  flex-direction: column;
}

.edit-form > .edit-form-row:not(:first-child),
.edit-form > .field-remark {
  margin-top: 28rpx;
}

.edit-form-row {
  display: flex;
  gap: 14rpx;
  min-width: 0;
  align-items: stretch;
}

.edit-form-row .edit-field {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.edit-form-row .edit-field > .edit-box,
.edit-form-row .edit-field > .edit-box-select,
.edit-form-row .edit-field > .edit-box-quantity {
  margin-top: auto;
  flex-shrink: 0;
  height: 80rpx;
}

.edit-form-row .edit-field-spacer {
  visibility: hidden;
  pointer-events: none;
}

.edit-form-row .edit-field-full {
  flex: 1 1 100%;
  width: 100%;
  max-width: 100%;
}

.edit-form .edit-field {
  min-width: 0;
  margin-bottom: 0;
  display: flex;
  flex-direction: column;
}

.edit-form .edit-field-head {
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 4rpx;
  min-width: 0;
  min-height: 32rpx;
}

.edit-form .edit-field-head .edit-label {
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 0.6rpx;
  color: #697386;
  line-height: 1.3;
}

.edit-form .edit-field-head .required-star {
  font-size: 22rpx;
  line-height: 1.3;
  color: #e74c3c;
  font-weight: 900;
}

.edit-form .edit-field-head .field-error-text {
  color: #e74c3c;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
}

.edit-form .edit-box {
  box-sizing: border-box;
  width: 100%;
  height: 80rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 1rpx solid #e3e7ec;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.95), 0 2rpx 10rpx rgba(17, 19, 24, 0.04);
  display: flex;
  align-items: center;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.edit-form .edit-box.is-error {
  border-color: #e74c3c;
  background: #fff9f9;
  box-shadow: inset 0 0 0 1rpx rgba(231, 76, 60, 0.08);
}

.edit-form .edit-box-input {
  flex: 1;
  width: 100%;
  min-width: 0;
  height: 80rpx;
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  font-size: 28rpx;
  color: #111318;
  font-weight: 600;
  line-height: 80rpx;
  display: block;
  box-sizing: border-box;
}

.edit-form .edit-box-input-grow {
  flex: 1;
  min-width: 0;
}

.edit-form .edit-box-select {
  padding: 0;
  border: 0;
  background: transparent;
  box-shadow: none;
}

.edit-form .edit-box-select .custom-select {
  width: 100%;
  height: 80rpx;
  margin: 0;
  min-width: 0;
}

.edit-form .edit-box-select .select-trigger {
  width: 100%;
  height: 80rpx;
  margin: 0;
  padding: 0 12rpx;
  gap: 6rpx;
  border: 1rpx solid #e3e7ec;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.95), 0 2rpx 10rpx rgba(17, 19, 24, 0.04);
  box-sizing: border-box;
}

.edit-form .edit-box-select .custom-select.is-error .select-trigger {
  border-color: #e74c3c;
  background: #fff9f9;
  box-shadow: inset 0 0 0 1rpx rgba(231, 76, 60, 0.08);
}

.edit-form .edit-box-select .select-value {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.edit-form .edit-box-select .select-arrow {
  flex: 0 0 auto;
  color: #9aa3af;
  font-size: 20rpx;
}

.edit-form .edit-box-weight {
  padding: 0;
}

.edit-form .edit-box-calorie {
  padding: 0;
}

.edit-form .edit-box-calorie .edit-box-input-grow {
  padding-left: 18rpx;
}

.edit-form .edit-box-unit-suffix {
  flex: 0 0 96rpx;
  width: 96rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-left: 1rpx solid #e8ebef;
  box-sizing: border-box;
  background: #f6f8fa;
  font-size: 24rpx;
  font-weight: 800;
  color: #697386;
}

.edit-form .edit-box-weight .edit-box-input-grow {
  padding-left: 18rpx;
}

.edit-form .edit-box-units {
  flex: 0 0 112rpx;
  width: 112rpx;
  height: 100%;
  display: flex;
  border-left: 1rpx solid #e8ebef;
  box-sizing: border-box;
  background: #f6f8fa;
}

.edit-form .edit-box-unit {
  flex: 1;
  min-width: 0;
  min-height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
  color: #697386;
}

.edit-form .edit-box-unit.active {
  background: #111827;
  color: #ffffff;
}

.edit-form .edit-box-unit + .edit-box-unit {
  border-left: 1rpx solid #e8ebef;
}

.edit-form .edit-box.is-error .edit-box-units {
  border-left-color: #f0b4b4;
}

.edit-form .edit-box-quantity {
  padding: 0;
  border: 0;
  background: transparent;
  box-shadow: none;
  height: 80rpx;
  align-items: stretch;
}

.edit-form .edit-box-quantity quantity-stepper {
  flex: 1;
  width: 100%;
  min-width: 0;
  display: block;
  height: 80rpx;
}

.edit-form .edit-field--quantity {
  flex: 0 0 192rpx;
  max-width: 192rpx;
  min-width: 176rpx;
}

.edit-form .edit-box-date {
  justify-content: space-between;
  gap: 10rpx;
}

.edit-form .edit-box-date-text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 26rpx;
  color: #111318;
  font-weight: 600;
}

.edit-form .edit-box-date-text.placeholder {
  color: #b1b6bc;
  font-weight: 500;
}

.edit-form .edit-box-date-arrow {
  flex: 0 0 auto;
  color: #697386;
  font-size: 20rpx;
  font-weight: 700;
}

.edit-form .field-remark .edit-box-textarea {
  width: 100%;
  height: auto;
  min-height: 112rpx;
  padding: 18rpx;
  align-items: flex-start;
  font-size: 28rpx;
  font-weight: 500;
  color: #111318;
  line-height: 1.55;
  border: 1rpx solid #e3e7ec;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.95), 0 2rpx 10rpx rgba(17, 19, 24, 0.04);
  transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}

.edit-form .edit-box-textarea.is-error {
  border-color: #e74c3c;
  background: #fff9f9;
  box-shadow: inset 0 0 0 1rpx rgba(231, 76, 60, 0.08);
}

.edit-form .field-image .edit-image-row {
  margin-top: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.edit-form .edit-preview,
.edit-form .edit-preview.placeholder {
  flex: 0 0 120rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 18rpx;
  background: #eef1f5;
}

.edit-form .edit-preview.placeholder {
  color: #9aa0a8;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 120rpx;
  text-align: center;
}

.edit-form .edit-image-actions {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.edit-form .edit-image-btn {
  height: 64rpx;
  border-radius: 18rpx;
  background: #111827;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 64rpx;
  text-align: center;
}

.edit-form .edit-image-btn.muted {
  background: #ffffff;
  color: #60666e;
  box-shadow: inset 0 0 0 1rpx #e2e4e6;
}

.gear-form-actions {
  margin-top: 8rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eef0f3;
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.gear-form-actions .edit-primary,
.gear-form-actions .edit-secondary {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 76rpx;
  text-align: center;
  box-sizing: border-box;
}

.gear-form-actions .edit-secondary {
  background: #ffffff;
  color: #8a8f96;
  border: 1rpx solid #e2e4e6;
}

.gear-form-actions .edit-primary {
  background: #050608;
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(5, 6, 8, 0.18);
}

.edit-modal .edit-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
  height: 58vh;
  max-height: 58vh;
  margin-top: 20rpx;
  box-sizing: border-box;
}

.modal-mask.form-modal-mask .edit-modal {
  max-height: 100%;
}

.modal-mask.form-modal-mask .edit-scroll {
  height: 58vh;
  max-height: 58vh;
}

.modal-mask.form-modal-mask .edit-form {
  padding-bottom: 72rpx;
}

@media (max-width: 360px) {
  .edit-form-row {
    gap: 12rpx;
  }

  .edit-form-row .edit-field-spacer {
    display: none;
  }

  .gear-form-actions .edit-primary,
  .gear-form-actions .edit-secondary {
    height: 72rpx;
    font-size: 25rpx;
    line-height: 72rpx;
  }
}
