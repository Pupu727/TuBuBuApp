page {
  min-height: 100vh;
  background: #f7f8f4;
  color: #111318;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  line-height: 1;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.screen {
  padding: 24rpx 22rpx calc(152rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.screen-empty {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.hero-card,
.breakdown-card,
.chart-card,
.system-card,
.empty-card {
  border: 1rpx solid #e8e9e6;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(17, 19, 24, 0.06);
}

.hero-card {
  padding: 30rpx;
}

.hero-head,
.plan-meta,
.system-head,
.system-title-row,
.system-title-aside,
.system-meta,
.gear-title-row,
.gear-meta,
.gear-tags,
.breakdown-legend,
.legend-item,
.legend-left,
.chart-row,
.chart-label,
.chart-metrics {
  display: flex;
  align-items: center;
}

.hero-head {
  justify-content: space-between;
  gap: 16rpx;
}

.hero-main {
  flex: 1;
  min-width: 0;
}

.plan-name {
  display: block;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.2;
}

.plan-meta {
  margin-top: 10rpx;
  min-width: 0;
  flex-wrap: wrap;
  gap: 4rpx;
}

.plan-route {
  color: #727a84;
  font-size: 24rpx;
  line-height: 34rpx;
}

.daynight-capsule {
  display: inline-block;
  vertical-align: top;
  position: relative;
  top: 3rpx;
  padding: 0 14rpx;
  height: 30rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 30rpx;
  white-space: nowrap;
  box-sizing: border-box;
}

.daynight-1 {
  background: #e8f1ff;
  color: #2563eb;
}

.daynight-2 {
  background: #e7f5e8;
  color: #237a35;
}

.daynight-3 {
  background: #fff3e0;
  color: #c56a00;
}

.daynight-4 {
  background: #f3e9ff;
  color: #7c3aed;
}

.daynight-5 {
  background: #ffe8ef;
  color: #c9356a;
}

.daynight-6 {
  background: #e7f7f7;
  color: #0f766e;
}

.daynight-7 {
  background: #f4f0e8;
  color: #8a5a17;
}

.default-badge {
  flex: 0 0 auto;
  padding: 7rpx 16rpx;
  border-radius: 14rpx;
  background: #e7f5e8;
  color: #237a35;
  font-size: 22rpx;
  font-weight: 900;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.stats-grid-secondary {
  margin-top: 14rpx;
}

.stat-card {
  min-width: 0;
  padding: 20rpx 18rpx;
  border-radius: 20rpx;
  background: #f8f9f7;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  gap: 10rpx;
}

.stat-card-wide {
  grid-column: span 2;
}

.stat-value {
  display: block;
  width: 100%;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
  min-height: 40rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.stat-label {
  display: block;
  width: 100%;
  color: #727a84;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.3;
}

.stat-value.purple {
  color: #7c3aed;
}

.stat-value.orange {
  color: #ea580c;
}

.stat-value.teal {
  color: #0f766e;
}

.stat-value.green {
  color: #237a35;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 900;
}

.chart-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.overview-switch {
  display: inline-flex;
  padding: 4rpx;
  border-radius: 999rpx;
  background: #f2f3f1;
  box-sizing: border-box;
}

.switch-option {
  min-width: 90rpx;
  height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #8a9097;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 48rpx;
  text-align: center;
  box-sizing: border-box;
}

.switch-option.active {
  color: #111318;
  background: #ffffff;
  box-shadow: 0 4rpx 10rpx rgba(17, 19, 24, 0.08);
}

.section-hint {
  display: block;
  margin-top: 8rpx;
  color: #8a8f96;
  font-size: 22rpx;
  font-weight: 700;
}

.breakdown-card,
.chart-card,
.empty-card {
  margin-top: 24rpx;
  padding: 28rpx 26rpx;
}

.anchor-strip {
  width: calc(100% + 44rpx);
  margin: 20rpx -22rpx 0;
  white-space: nowrap;
}

.anchor-track {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 2rpx 22rpx 6rpx;
}

.anchor-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(17, 19, 24, 0.08);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.45);
  box-sizing: border-box;
}

.anchor-chip.is-active {
  border-color: rgba(17, 19, 24, 0.16);
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 6rpx 18rpx rgba(17, 19, 24, 0.05);
}

.anchor-chip:active {
  opacity: 0.88;
}

.anchor-dot {
  flex: 0 0 12rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.anchor-label {
  color: #6a7179;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.2;
  white-space: nowrap;
}

.anchor-chip.is-active .anchor-label {
  color: #111318;
}

.systems-wrap {
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  row-gap: 14rpx;
}

.systems-wrap.has-anchors {
  margin-top: 16rpx;
}

.system-card {
  width: calc(50% - 7rpx);
  margin-top: 0;
  overflow: hidden;
  box-sizing: border-box;
}

.system-card:first-child {
  margin-top: 0;
}

.system-head {
  gap: 16rpx;
  padding: 22rpx 22rpx 22rpx 0;
  min-width: 0;
}

.system-accent {
  flex: 0 0 8rpx;
  align-self: stretch;
  width: 8rpx;
  border-radius: 0 8rpx 8rpx 0;
}

.system-main {
  flex: 1;
  min-width: 0;
}

.system-title-row {
  justify-content: space-between;
  gap: 12rpx;
  min-width: 0;
}

.system-title-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6rpx;
}

.system-title-aside {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.system-name {
  min-width: 0;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.system-caret {
  flex: 0 0 auto;
  color: #8a8f96;
  font-size: 22rpx;
}

.system-meta {
  flex-wrap: wrap;
  gap: 2rpx;
  margin-top: 6rpx;
  color: #727a84;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.3;
}

.system-meta-item {
  white-space: nowrap;
}

.system-meta-dot {
  color: #a0a6ae;
  padding: 0 1rpx;
}

.system-calorie {
  flex: 0 0 auto;
  color: #c56a00;
  font-size: 21rpx;
  font-weight: 900;
  white-space: nowrap;
}

.system-value {
  flex: 0 0 auto;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
}

.system-items {
  padding: 0 22rpx 22rpx 30rpx;
}

.gear-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(17, 19, 24, 0.06);
}

.gear-main {
  flex: 1;
  min-width: 0;
}

.gear-title-row {
  gap: 8rpx;
  min-width: 0;
  justify-content: space-between;
}

.gear-title-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.gear-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 26rpx;
  font-weight: 800;
}

.gear-calorie {
  flex: 0 0 auto;
  color: #c56a00;
  font-size: 21rpx;
  font-weight: 900;
  white-space: nowrap;
}

.gear-qty {
  flex: 0 0 auto;
  color: #727a84;
  font-size: 22rpx;
  font-weight: 800;
}

.gear-meta {
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 6rpx;
  color: #8a8f96;
  font-size: 21rpx;
  font-weight: 700;
}

.gear-tags {
  flex: 0 0 auto;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.status-chip {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  white-space: nowrap;
}

.carry-carried {
  background: #eef0ff;
  color: #5d6de8;
}

.carry-worn {
  background: #edf8f2;
  color: #237a35;
}

.carry-consumable {
  background: #fff5ea;
  color: #c56a00;
}

.carry-shared {
  background: #f3f4f5;
  color: #727a84;
}

.gear-status-using {
  background: #e9dcff;
  color: #5f34b7;
}

.gear-status-idle {
  background: #eef0f2;
  color: #60666e;
}

.gear-status-wishlist {
  background: #e9f6ff;
  color: #2081cc;
}

.gear-status-broken {
  background: #fdecea;
  color: #c0392b;
}

.gear-status-borrowed {
  background: #fff1ca;
  color: #bf8210;
}

.packed-done {
  background: #e7f5e8;
  color: #237a35;
}

.packed-open {
  background: #f3f4f5;
  color: #727a84;
}

.packed-missing {
  background: #ffecec;
  color: #c93434;
}

.packed-skip {
  background: #f8f9f7;
  color: #9aa0a6;
}

.empty-card {
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-copy {
  display: block;
  margin-top: 12rpx;
  color: #727a84;
  font-size: 24rpx;
  line-height: 1.5;
}

.dark-button {
  width: 226rpx;
  max-width: 100%;
  height: 74rpx;
  margin: 34rpx auto 0;
  border-radius: 38rpx;
  background: #111318;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 74rpx;
  text-align: center;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding: 16rpx 22rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e8e9e6;
  background: #ffffff;
  box-sizing: border-box;
}

.bottom-primary {
  width: 100%;
  height: 84rpx;
  border-radius: 20rpx;
  background: #111318;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 84rpx;
  text-align: center;
  box-sizing: border-box;
}

.bottom-primary:active {
  opacity: 0.92;
}
