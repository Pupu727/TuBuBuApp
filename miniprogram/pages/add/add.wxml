<scroll-view class="page" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="screen">
    <view class="hero-card">
      <view class="hero-copy">
        <text class="hero-kicker">LOCAL GEAR PARSE</text>
        <text class="hero-title">智能添加入口</text>
        <text class="hero-desc">批量输入装备名称，后续用本地规则生成重量、价格、分类和备注。</text>
        <view class="hero-tags">
          <text>本地规则</text>
          <text>预览后保存</text>
        </view>
      </view>
      <view class="hero-badge">AI</view>
    </view>

    <view class="form-card">
      <view class="form-title-row">
        <view class="title-mark"></view>
        <text class="section-title">手动新增装备</text>
      </view>

      <view class="edit-form">
        <view class="edit-form-row">
          <view class="edit-field">
            <view class="edit-field-head">
              <text class="edit-label">装备名称</text>
              <text class="required-star">*</text>
              <text wx:if="{{showErrors && errors.name}}" class="field-error-text">不能为空</text>
              <text wx:elif="{{limits.name}}" class="field-error-text">字数超过上限</text>
            </view>
            <view class="edit-box {{(showErrors && errors.name) || limits.name ? 'is-error' : ''}}">
              <input
                class="edit-box-input"
                value="{{form.name}}"
                placeholder="如 艾王 35+5L"
                adjust-position="{{true}}"
                cursor-spacing="120"
                bindinput="onInputName"
              />
            </view>
          </view>
          <view class="edit-field">
            <view class="edit-field-head">
              <text class="edit-label">重量</text>
              <text class="required-star">*</text>
              <text wx:if="{{showErrors && errors.weight}}" class="field-error-text">不能为空</text>
              <text wx:elif="{{limits.weight}}" class="field-error-text">超过上限</text>
            </view>
            <view class="edit-box edit-box-weight {{(showErrors && errors.weight) || limits.weight ? 'is-error' : ''}}">
              <input
                class="edit-box-input edit-box-input-grow"
                type="digit"
                value="{{form.weightValue}}"
                placeholder="如 1100"
                adjust-position="{{true}}"
                cursor-spacing="120"
                bindinput="onInputWeight"
              />
              <view class="edit-box-units">
                <view class="edit-box-unit {{form.weightUnit === 'g' ? 'active' : ''}}" data-unit="g" bindtap="onWeightUnitTap">g</view>
                <view class="edit-box-unit {{form.weightUnit === 'kg' ? 'active' : ''}}" data-unit="kg" bindtap="onWeightUnitTap">kg</view>
              </view>
            </view>
          </view>
        </view>

        <view class="edit-form-row">
          <view class="edit-field">
            <view class="edit-field-head">
              <text class="edit-label">价格（元）</text>
              <text wx:if="{{limits.price}}" class="field-error-text">超过上限</text>
            </view>
            <view class="edit-box {{limits.price ? 'is-error' : ''}}">
              <input
                class="edit-box-input"
                type="digit"
                value="{{form.priceYuan}}"
                placeholder="可选"
                adjust-position="{{true}}"
                cursor-spacing="120"
                bindinput="onInputPrice"
              />
            </view>
          </view>
          <view class="edit-field">
            <view class="edit-field-head">
              <text class="edit-label">购买日期</text>
            </view>
            <view class="edit-box edit-box-date" bindtap="openAddDatePicker">
              <text class="edit-box-date-text {{form.purchase_date ? '' : 'placeholder'}}">{{form.purchase_date || '未设置'}}</text>
              <text class="edit-box-date-arrow">▾</text>
            </view>
          </view>
        </view>

        <view class="edit-form-row">
          <view class="edit-field">
            <view class="edit-field-head">
              <text class="edit-label">分类</text>
              <text class="required-star">*</text>
            </view>
            <view class="edit-box edit-box-select">
              <custom-select
                embedded="{{true}}"
                elevated="{{true}}"
                options="{{categoryOptions}}"
                value="{{form.category}}"
                placeholder="选择分类"
                bind:change="onCategoryChange"
              />
            </view>
          </view>
          <view class="edit-field">
            <view class="edit-field-head">
              <text class="edit-label">状态</text>
            </view>
            <view class="edit-box edit-box-select">
              <block wx:for="{{[form.category]}}" wx:key="*this">
                <custom-select
                  embedded="{{true}}"
                  elevated="{{true}}"
                  options="{{statusOptions}}"
                  value="{{form.status}}"
                  placeholder="选择状态"
                  bind:change="onStatusChange"
                />
              </block>
            </view>
          </view>
          <view class="edit-field edit-field--quantity">
            <view class="edit-field-head">
              <text class="edit-label">数量</text>
              <text wx:if="{{limits.quantity}}" class="field-error-text">超出限制</text>
            </view>
            <view class="edit-box edit-box-quantity {{limits.quantity ? 'is-error' : ''}}">
              <quantity-stepper
                value="{{form.quantity}}"
                min="{{1}}"
                max="{{50}}"
                bind:change="onQuantityChange"
                bind:limit="onQuantityLimit"
              />
            </view>
          </view>
        </view>

        <view class="edit-form-row">
          <view wx:if="{{form.category === 'supply'}}" class="edit-field edit-field-full">
            <view class="edit-field-head">
              <text class="edit-label">热量</text>
              <text class="required-star">*</text>
              <text wx:if="{{showErrors && errors.calorie}}" class="field-error-text">不能为空</text>
              <text wx:elif="{{limits.calorie}}" class="field-error-text">超过上限</text>
            </view>
            <view class="edit-box edit-box-calorie {{(showErrors && errors.calorie) || limits.calorie ? 'is-error' : ''}}">
              <input
                class="edit-box-input edit-box-input-grow"
                type="digit"
                value="{{form.calorieKcalValue}}"
                placeholder="如 450"
                adjust-position="{{true}}"
                cursor-spacing="120"
                bindinput="onInputCalorie"
              />
              <view class="edit-box-unit-suffix">kcal</view>
            </view>
          </view>
          <view wx:else class="edit-field edit-field-full">
            <view class="edit-field-head">
              <text class="edit-label">购买渠道</text>
            <text wx:if="{{limits.channel}}" class="field-error-text">字数超过上限</text>
            </view>
          <view class="edit-box {{limits.channel ? 'is-error' : ''}}">
              <input
                class="edit-box-input"
                value="{{form.channel}}"
                placeholder="如 淘宝、线下店"
                adjust-position="{{true}}"
                cursor-spacing="120"
                bindinput="onInputChannel"
              />
            </view>
          </view>
        </view>

        <view class="edit-field field-remark">
          <view class="edit-field-head">
            <text class="edit-label">备注</text>
            <text wx:if="{{limits.remark}}" class="field-error-text">字数超过上限</text>
          </view>
          <textarea
            class="edit-box edit-box-textarea {{limits.remark ? 'is-error' : ''}}"
            value="{{form.remark}}"
            placeholder="颜色、用途等"
            adjust-position="{{true}}"
            cursor-spacing="120"
            bindinput="onInputRemark"
          />
        </view>
      </view>

      <view class="gear-form-actions">
        <view class="edit-primary" bindtap="saveGear">保存装备</view>
        <view class="edit-secondary" bindtap="clearForm">清空</view>
      </view>
    </view>
  </view>
</scroll-view>

<custom-date-picker
  id="addDatePicker"
  hide-trigger="{{true}}"
  floating="{{true}}"
  compact
  value="{{form.purchase_date}}"
  placeholder="未设置"
  bind:change="onPurchaseDateChange"
/>

<app-loading
  show="{{showTransitionLoading}}"
  text="{{transitionLoadingText}}"
/>
