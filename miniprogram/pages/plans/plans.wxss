@import '../../styles/danger-button.wxss';

page {
  min-height: 100vh;
  background: #f7f8f4;
  color: #111318;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  line-height: 1;
}

button::after {
  border: 0;
}

.page {
  height: 100vh;
}

.screen {
  padding: 34rpx 24rpx calc(280rpx + constant(safe-area-inset-bottom));
  padding: 34rpx 24rpx calc(280rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.plans-index {
  margin-bottom: 20rpx;
  padding: 20rpx 22rpx 20rpx 26rpx;
  border-left: 8rpx solid #2f6f44;
  border-radius: 0 20rpx 20rpx 0;
  background: linear-gradient(90deg, rgba(47, 111, 68, 0.08) 0%, rgba(247, 248, 244, 0) 72%);
}

.plans-index--empty {
  border-left-color: #c5cad0;
  background: linear-gradient(90deg, rgba(17, 19, 24, 0.04) 0%, rgba(247, 248, 244, 0) 72%);
}

.plans-index-spotlight-title,
.plans-index-insight-text,
.plans-index-insight-text--solo,
.plans-index-metric-value,
.plans-index-metric-label,
.plans-index-empty-text,
.plans-section-title,
.plans-section-count {
  display: block;
}

.plans-index-spotlight-title {
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.3;
}

.plans-index-insight {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
  min-width: 0;
}

.plans-index-insight-text {
  color: #6f7680;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.plans-index-insight .trip-date-capsule {
  padding: 6rpx 14rpx;
  font-size: 26rpx;
  line-height: 1.2;
}

.plans-index-insight-text--solo {
  display: block;
  margin-top: 8rpx;
}

.plans-index-metrics {
  display: flex;
  align-items: center;
  gap: 0;
  margin-top: 16rpx;
  min-width: 0;
}

.plans-index-metric {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.plans-index-metric-divider {
  flex: 0 0 auto;
  width: 1rpx;
  height: 44rpx;
  background: rgba(17, 19, 24, 0.1);
}

.plans-index-metric-value {
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.15;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.plans-index-metric-label {
  margin-top: 4rpx;
  color: #8b9096;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.2;
}

.plans-index-empty-text {
  color: #6f7680;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.5;
}

.plans-section-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 14rpx;
  min-width: 0;
}

.plans-section-toggle {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 12rpx;
  margin-top: 18rpx;
  margin-bottom: 14rpx;
  min-width: 0;
}

.plans-section-toggle:active {
  opacity: 0.86;
}

.plans-section-caret {
  flex: 0 0 auto;
  margin-left: auto;
  color: #8b9096;
  font-size: 22rpx;
  font-weight: 900;
}

.plans-section-title {
  color: #111318;
  font-size: 26rpx;
  font-weight: 900;
}

.plans-section-count {
  flex: 0 0 auto;
  color: #8b9096;
  font-size: 22rpx;
  font-weight: 700;
}

.title,
.plan-name,
.plan-meta-route,
.plan-weight,
.plan-stats-line,
.plan-remark-preview,
.plan-weight-label,
.empty-text {
  display: block;
}

.page-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 58rpx;
  margin-bottom: 22rpx;
  min-width: 0;
}

.page-head-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.title {
  flex: 0 0 auto;
  min-width: 0;
  margin-bottom: 0;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 58rpx;
}

.snapshot-help-btn {
  flex: 0 0 auto;
  align-self: center;
  width: 44rpx;
  height: 44rpx;
  margin-top: 0;
  border-radius: 50%;
  border: 1rpx solid #e7ebf0;
  background: #f9fafb;
  color: #9aa3af;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-align: center;
  box-sizing: border-box;
}

.snapshot-help-btn:active {
  background: #f1f4f6;
  color: #8a939f;
}

.add-plan-btn {
  flex: 0 0 auto;
  align-self: center;
  height: 58rpx;
  padding: 0 28rpx;
  margin-bottom: 0;
  margin-left: auto;
  border-radius: 14rpx;
  background: #111827;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 58rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(17, 24, 39, 0.16);
}

.add-plan-btn:active {
  opacity: 0.92;
}

.plan-swipe,
.plan-card,
.empty {
  margin-top: 0;
}

.plan-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx 12rpx;
  align-items: stretch;
}

.plan-grid .plan-swipe {
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.plan-card,
.empty {
  padding: 20rpx 16rpx;
  border: 1rpx solid #e8e9e6;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(17, 19, 24, 0.05);
}

.plan-card--completed {
  border-color: rgba(17, 19, 24, 0.08);
  background: rgba(255, 255, 255, 0.85);
  box-shadow: 0 6rpx 18rpx rgba(17, 19, 24, 0.04);
}

.plan-swipe {
  position: relative;
  overflow: visible;
  border-radius: 22rpx;
}

.plan-card {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  width: 100%;
  min-height: 252rpx;
  box-sizing: border-box;
  transition: transform 180ms ease;
  will-change: transform;
}

.plan-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  display: flex;
  overflow: hidden;
  border-radius: 0 22rpx 22rpx 0;
  transition: width 160ms ease;
}

.plan-action {
  flex: 1;
  min-width: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}

.trash-icon {
  position: relative;
  width: 34rpx;
  height: 38rpx;
}

.trash-lid {
  position: absolute;
  left: 4rpx;
  top: 2rpx;
  width: 26rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.trash-lid::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: -5rpx;
  width: 10rpx;
  height: 5rpx;
  border-radius: 4rpx 4rpx 0 0;
  background: #ffffff;
}

.trash-can {
  position: absolute;
  left: 6rpx;
  top: 12rpx;
  display: flex;
  justify-content: center;
  gap: 6rpx;
  width: 22rpx;
  height: 24rpx;
  padding-top: 5rpx;
  border: 4rpx solid #ffffff;
  border-top: 0;
  border-radius: 0 0 5rpx 5rpx;
  box-sizing: border-box;
}

.trash-line {
  width: 3rpx;
  height: 13rpx;
  border-radius: 999rpx;
  background: #ffffff;
  opacity: 0.82;
}

.empty {
  margin-top: 0;
}

.empty {
  margin-top: 0;
}

.plan-card:active {
  opacity: 0.96;
}

.name-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 4rpx;
  min-width: 0;
}

.plan-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.name-title-wrap {
  flex: 1;
  min-width: 0;
}

.plan-name {
  flex: 1 1 auto;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.name-actions {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  gap: 2rpx;
}

.plan-icon-btn {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border: 0;
  border-radius: 14rpx;
  background: transparent;
  box-sizing: border-box;
}

.plan-grid .plan-icon-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
}

.plan-icon-btn--overview {
  border: 1rpx solid #d4e8fb;
  background: #edf6ff;
}

.plan-icon-btn--overview:active {
  background: #e4f1fc;
}

.plan-icon-glyph {
  line-height: 1;
}

.plan-grid .plan-icon-glyph--edit {
  font-size: 24rpx;
}

.plan-grid .plan-icon-glyph--list {
  font-size: 24rpx;
}

.plan-icon-glyph--edit {
  font-size: 26rpx;
  color: #7b838d;
  font-weight: 400;
  transform: scaleX(-1);
}

.plan-icon-glyph--list {
  font-size: 26rpx;
  font-weight: 900;
  color: #3b7ec6;
  letter-spacing: -2rpx;
}

.plan-icon-btn:active {
  opacity: 0.88;
  transform: scale(0.96);
}

.plan-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #f0f1ee;
  min-width: 0;
}

.plan-weight-wrap {
  display: flex;
  flex: 0 0 auto;
  align-items: baseline;
  gap: 6rpx;
  margin-left: auto;
}

.plan-footer .trip-date-capsule {
  flex: 0 1 auto;
  min-width: 0;
  padding: 6rpx 12rpx;
  font-size: 22rpx;
  line-height: 1.2;
}

.plan-weight-label {
  color: #8b9096;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
}

.plan-weight {
  flex: 0 0 auto;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.2;
  white-space: nowrap;
}

.badge,
.trip-date-capsule {
  flex: 0 0 auto;
  padding: 5rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.2;
  white-space: nowrap;
}

.trip-date-capsule {
  display: inline-block;
}

.trip-date--today {
  background: #ffe8ef;
  color: #c9356a;
}

.trip-date--soon {
  background: #fff3e0;
  color: #c56a00;
}

.trip-date--near {
  background: #e8f1ff;
  color: #2563eb;
}

.trip-date--far {
  background: #e7f5e8;
  color: #237a35;
}

.trip-date--past,
.trip-date--unset {
  background: #eef0f2;
  color: #8a9098;
}

.plan-detail-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  column-gap: 8rpx;
  row-gap: 2rpx;
  margin-top: 8rpx;
  align-items: start;
  min-width: 0;
}

.plan-meta-route {
  grid-column: 1;
  grid-row: 1;
  min-width: 0;
  display: block;
  color: #4f5660;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plan-tag-stack {
  grid-column: 2;
  grid-row: 1 / 3;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.plan-stats-line {
  grid-column: 1;
  grid-row: 2;
  display: block;
  margin-top: 0;
  min-width: 0;
  color: #4f5660;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plan-remark-preview {
  grid-column: 1 / -1;
  grid-row: 3;
  display: block;
  margin-top: 4rpx;
  min-width: 0;
  color: #8a9098;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1.4;
  white-space: normal;
  word-break: break-all;
}

.plan-remark-preview--empty {
  color: #b5bbc3;
}

.pack-capsule {
  display: inline-block;
  padding: 0 10rpx;
  height: 28rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 28rpx;
  letter-spacing: 0.5rpx;
  white-space: nowrap;
  box-sizing: border-box;
}

.pack-capsule--done {
  background: #e7f5e8;
  color: #237a35;
}

.pack-capsule--progress {
  background: #fff3e0;
  color: #c56a00;
}

.pack-capsule--pending {
  background: #eef0f2;
  color: #8a9098;
}

.pack-capsule--completed {
  background: rgba(17, 19, 24, 0.06);
  color: #6f7680;
}

.plan-stats-line--empty {
  color: #9aa3af;
}

.pack-progress {
  margin-top: auto;
  padding-top: 10rpx;
  min-width: 0;
}

.pack-progress-track {
  width: 100%;
  min-width: 0;
  height: 10rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #eef0f2;
}

.pack-progress-fill {
  height: 100%;
  min-width: 4rpx;
  border-radius: 999rpx;
}

.trip-progress-fill--active {
  background: linear-gradient(90deg, #3b9f5a 0%, #52b86d 100%);
}

.trip-progress-fill--soon {
  background: linear-gradient(90deg, #e58b1f 0%, #f3a53b 100%);
}

.trip-progress-fill--past {
  background: #c5cad0;
}

.trip-progress-fill--unset {
  background: #d7dbe0;
}

.pack-progress-placeholder {
  width: 100%;
  height: 100%;
  background: #e8eaed;
}

.daynight-capsule {
  display: inline-block;
  padding: 0 10rpx;
  height: 28rpx;
  border-radius: 999rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 28rpx;
  letter-spacing: 0.5rpx;
  white-space: nowrap;
  box-sizing: border-box;
}

.daynight-1 {
  background: #e8f1ff;
  color: #2563eb;
}

.daynight-2 {
  background: #e7f5e8;
  color: #237a35;
}

.daynight-3 {
  background: #fff3e0;
  color: #c56a00;
}

.daynight-4 {
  background: #f3e9ff;
  color: #7c3aed;
}

.daynight-5 {
  background: #ffe8ef;
  color: #c9356a;
}

.daynight-6 {
  background: #fff8db;
  color: #b45309;
}

.daynight-7 {
  background: #e6fbfb;
  color: #0f766e;
}

.empty {
  padding: 40rpx 24rpx 36rpx;
  color: #727a84;
  text-align: center;
}

.empty-title,
.empty-desc {
  display: block;
}

.empty-title {
  color: #111318;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-desc {
  margin-top: 12rpx;
  color: #8a8f96;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.5;
}

.empty button,
.empty-text {
  display: block;
}

.empty button {
  height: 74rpx;
  margin: 28rpx auto 0;
  padding: 0 32rpx;
  border-radius: 38rpx;
  background: #111318;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 74rpx;
}

.empty-text {
  font-size: 28rpx;
  font-weight: 800;
}

.dark-button {
  width: 226rpx;
  max-width: 100%;
  height: 74rpx;
  margin: 34rpx auto 0;
  border-radius: 38rpx;
  background: #111318;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 74rpx;
  text-align: center;
}

.help-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(17, 19, 24, 0.42);
  box-sizing: border-box;
}

.help-panel {
  position: relative;
  width: 100%;
  max-width: 620rpx;
  padding: 34rpx 28rpx 28rpx;
  border: 1rpx solid #e8e9e6;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(17, 19, 24, 0.12);
  box-sizing: border-box;
}

.help-close {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #f4f5f6;
  color: #8b9096;
  font-size: 42rpx;
  line-height: 54rpx;
  text-align: center;
}

.help-badge,
.help-title,
.help-copy {
  display: block;
}

.help-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  background: #e9f6ff;
  color: #2081cc;
  font-size: 22rpx;
  font-weight: 900;
}

.help-title {
  margin-top: 20rpx;
  padding-right: 74rpx;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.3;
}

.help-copy {
  margin-top: 14rpx;
  color: #6f7680;
  font-size: 25rpx;
  line-height: 1.5;
}

.help-primary {
  height: 76rpx;
  margin-top: 24rpx;
  border-radius: 16rpx;
  background: #050608;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 76rpx;
  text-align: center;
}
