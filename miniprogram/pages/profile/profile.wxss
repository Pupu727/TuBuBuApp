page {
  min-height: 100vh;
  background: #f7f8f4;
  color: #111318;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

.page {
  height: 100vh;
}

.screen {
  padding: 28rpx 24rpx calc(210rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.profile-eyebrow,
.profile-title,
.profile-desc,
.profile-stat-value,
.profile-stat-label,
.section-title,
.section-plan-name,
.section-plan-meta,
.action-label,
.setting-label,
.setting-desc,
.version-text {
  display: block;
}

.profile-hero {
  padding: 30rpx 28rpx 26rpx;
  border: 1rpx solid #e8e9e6;
  border-radius: 34rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(17, 19, 24, 0.08);
}

.profile-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  min-width: 0;
}

.profile-hero-top > view:first-child {
  flex: 1;
  min-width: 0;
}

.profile-eyebrow {
  color: #7d838c;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.profile-title {
  margin-top: 12rpx;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.15;
}

.profile-desc {
  margin-top: 14rpx;
  color: #727a84;
  font-size: 24rpx;
  line-height: 1.55;
}

.profile-mark {
  flex: 0 0 auto;
  width: 88rpx;
  height: 88rpx;
  border-radius: 26rpx;
  background: #111318;
  color: #b9ff2f;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 88rpx;
  text-align: center;
}

.profile-stats {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding: 22rpx 12rpx;
  border-radius: 24rpx;
  background: #f3f5f0;
}

.profile-stat {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.profile-stat-value {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.1;
}

.profile-stat-value--compact {
  font-size: 30rpx;
}

.profile-stat-label {
  margin-top: 8rpx;
  color: #7d838c;
  font-size: 22rpx;
  font-weight: 700;
}

.profile-stat-divider {
  width: 1rpx;
  height: 52rpx;
  background: #dde0da;
}

.section-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border: 1rpx solid #e8e9e6;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(17, 19, 24, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 900;
}

.section-plan-name {
  margin-top: 16rpx;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
}

.section-plan-meta {
  margin-top: 10rpx;
  color: #727a84;
  font-size: 24rpx;
  font-weight: 700;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 22rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  padding: 20rpx 18rpx;
  border: 1rpx solid #eceeeb;
  border-radius: 24rpx;
  background: #fafbf8;
  box-sizing: border-box;
}

.action-item:active {
  background: #f1f3ee;
}

.action-icon {
  flex: 0 0 auto;
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background: #111318;
  position: relative;
}

.action-label {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.3;
}

.action-icon--gear::before,
.action-icon--gear::after,
.action-icon--plans::before,
.action-icon--plans::after,
.action-icon--pack::before,
.action-icon--pack::after,
.action-icon--add::before,
.action-icon--add::after,
.setting-icon--storage::before,
.setting-icon--storage::after,
.setting-icon--sync::before,
.setting-icon--sync::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.action-icon--gear::before {
  left: 16rpx;
  top: 14rpx;
  width: 20rpx;
  height: 22rpx;
  border: 3rpx solid #b9ff2f;
  border-radius: 4rpx;
}

.action-icon--gear::after {
  left: 22rpx;
  top: 10rpx;
  width: 8rpx;
  height: 6rpx;
  border-top: 3rpx solid #b9ff2f;
  border-left: 3rpx solid #b9ff2f;
  border-right: 3rpx solid #b9ff2f;
  border-radius: 6rpx 6rpx 0 0;
}

.action-icon--plans::before {
  left: 13rpx;
  top: 14rpx;
  width: 26rpx;
  height: 24rpx;
  border: 3rpx solid #b9ff2f;
  border-radius: 4rpx;
}

.action-icon--plans::after {
  left: 13rpx;
  top: 14rpx;
  width: 26rpx;
  height: 24rpx;
  border-top: 3rpx solid #b9ff2f;
  border-left: 3rpx solid #b9ff2f;
  transform: skewY(-18deg);
  transform-origin: left top;
  border-radius: 4rpx;
}

.action-icon--pack::before {
  left: 15rpx;
  top: 16rpx;
  width: 22rpx;
  height: 18rpx;
  border: 3rpx solid #b9ff2f;
  border-radius: 6rpx;
}

.action-icon--pack::after {
  left: 21rpx;
  top: 12rpx;
  width: 10rpx;
  height: 6rpx;
  border: 3rpx solid #b9ff2f;
  border-bottom: 0;
  border-radius: 6rpx 6rpx 0 0;
}

.action-icon--add::before {
  left: 24rpx;
  top: 14rpx;
  width: 4rpx;
  height: 24rpx;
  background: #b9ff2f;
  border-radius: 2rpx;
}

.action-icon--add::after {
  left: 14rpx;
  top: 24rpx;
  width: 24rpx;
  height: 4rpx;
  background: #b9ff2f;
  border-radius: 2rpx;
}

.setting-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 22rpx;
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid #eceeeb;
  min-width: 0;
}

.setting-row--last {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: 0;
}

.setting-icon {
  flex: 0 0 auto;
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: #f3f5f0;
  position: relative;
}

.setting-copy {
  flex: 1;
  min-width: 0;
}

.setting-label {
  font-size: 28rpx;
  font-weight: 900;
}

.setting-desc {
  margin-top: 8rpx;
  color: #727a84;
  font-size: 24rpx;
  line-height: 1.45;
}

.setting-icon--storage::before {
  left: 14rpx;
  top: 16rpx;
  width: 28rpx;
  height: 20rpx;
  border: 3rpx solid #111318;
  border-radius: 4rpx;
}

.setting-icon--storage::after {
  left: 20rpx;
  top: 12rpx;
  width: 16rpx;
  height: 6rpx;
  border: 3rpx solid #111318;
  border-bottom: 0;
  border-radius: 4rpx 4rpx 0 0;
}

.setting-icon--sync::before {
  left: 18rpx;
  top: 14rpx;
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid #111318;
  border-radius: 50%;
  border-right-color: transparent;
  transform: rotate(35deg);
}

.setting-icon--sync::after {
  left: 28rpx;
  top: 12rpx;
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-bottom: 8rpx solid #111318;
  transform: rotate(35deg);
}

.version-text {
  margin-top: 24rpx;
  margin-bottom: 8rpx;
  text-align: center;
  color: #a0a6ad;
  font-size: 22rpx;
  font-weight: 700;
}

@media (max-width: 360px) {
  .profile-title {
    font-size: 40rpx;
  }

  .profile-stat-value {
    font-size: 32rpx;
  }

  .profile-stat-value--compact {
    font-size: 26rpx;
  }
}
