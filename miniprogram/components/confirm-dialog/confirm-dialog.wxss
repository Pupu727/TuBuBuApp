@import '../../styles/danger-button.wxss';

.confirm-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1400;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(17, 19, 24, 0.35);
  box-sizing: border-box;
}

.confirm-panel {
  width: 100%;
  max-width: 560rpx;
  padding: 32rpx 28rpx 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 64rpx rgba(17, 19, 24, 0.22);
  box-sizing: border-box;
}

.confirm-title {
  display: block;
  font-size: 32rpx;
  font-weight: 900;
  color: #111318;
}

.confirm-content {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #697386;
}

.confirm-actions {
  margin-top: 28rpx;
  display: flex;
  gap: 12rpx;
}

.confirm-btn {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 76rpx;
  text-align: center;
  box-sizing: border-box;
}

.confirm-btn.muted {
  background: #ffffff;
  color: #8a8f96;
  box-shadow: inset 0 0 0 1rpx #e2e4e6;
}

.confirm-btn.primary {
  background: #050608;
  color: #ffffff;
}
