@import '../../styles/modal-layout.wxss';

.edit-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1700;
  background: rgba(17, 19, 24, 0.42);
  box-sizing: border-box;
}

.edit-panel {
  width: 100%;
  max-width: 620rpx;
  max-height: 86vh;
  padding: 34rpx 28rpx 28rpx;
  border: 1rpx solid #e8e9e6;
  border-radius: 24rpx;
  background: #ffffff;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.edit-panel-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
  height: 52vh;
  max-height: 52vh;
  box-sizing: border-box;
}

.edit-mask.form-edit-mask .edit-panel {
  max-height: 100%;
}

.form-edit-mask .edit-panel-scroll {
  height: 52vh;
  max-height: 52vh;
}

.edit-keyboard-spacer {
  height: 72rpx;
}

.edit-title {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
}

.edit-field {
  margin-top: 22rpx;
}

.edit-field-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.edit-label {
  display: block;
  flex: 0 0 auto;
  margin-bottom: 10rpx;
  color: #8a8f96;
  font-size: 24rpx;
  font-weight: 800;
}

.field-error-text {
  margin-left: auto;
  margin-bottom: 10rpx;
  color: #d74242;
  font-size: 22rpx;
  font-weight: 800;
}

.required-star {
  margin-bottom: 10rpx;
  color: #d74242;
  font-size: 24rpx;
  font-weight: 800;
}

.edit-input-shell {
  border: 1rpx solid #e2e4e6;
  border-radius: 16rpx;
  background: #fbfbfa;
}

.edit-input {
  width: 100%;
  height: 76rpx;
  padding: 0 20rpx;
  border: 0;
  border-radius: 16rpx;
  background: transparent;
  box-sizing: border-box;
  font-size: 28rpx;
}

.edit-input-shell.is-error,
.edit-input.is-error,
.edit-textarea.is-error {
  border-color: #f1a9a9;
  background: #fff7f7;
}

.edit-textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #e2e4e6;
  border-radius: 16rpx;
  background: #fbfbfa;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.45;
}

.edit-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 28rpx;
  flex-shrink: 0;
}

.edit-cancel,
.edit-save {
  flex: 1;
  height: 76rpx;
  margin: 0;
  padding: 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 76rpx;
}

.edit-cancel {
  border: 1rpx solid #e2e4e6;
  color: #777d84;
  background: #ffffff;
}

.edit-save {
  background: #050608;
  color: #ffffff;
}
