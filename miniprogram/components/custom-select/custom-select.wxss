.custom-select {
  position: relative;
  margin-top: 12rpx;
  min-width: 0;
}

.custom-select.compact {
  margin-top: 0;
  flex: 0 0 112rpx;
  width: 112rpx;
}

.custom-select.embedded {
  margin-top: 0;
  width: 100%;
  height: 80rpx;
  min-width: 0;
}

.embedded .select-trigger {
  width: 100%;
  height: 80rpx;
  margin: 0;
  padding: 0 12rpx;
  gap: 6rpx;
  border: 1rpx solid #e3e7ec;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.95), 0 2rpx 10rpx rgba(17, 19, 24, 0.04);
  box-sizing: border-box;
}

.embedded.is-error .select-trigger {
  border-color: #e74c3c;
  background: #fff9f9;
  box-shadow: inset 0 0 0 1rpx rgba(231, 76, 60, 0.08);
}

.embedded .select-value {
  font-size: 26rpx;
  font-weight: 600;
}

.embedded .select-arrow {
  color: #9aa3af;
  font-size: 20rpx;
}

.select-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  height: 84rpx;
  padding: 0 18rpx;
  border: 1rpx solid #e5e8eb;
  border-radius: 18rpx;
  background: #fbfcfd;
  box-sizing: border-box;
}

.compact .select-trigger {
  height: 100%;
  min-height: 76rpx;
  padding: 0 12rpx;
  border: 0;
  border-left: 1rpx solid #e5e8eb;
  border-radius: 0;
  background: #f4f6f8;
}

.compact .select-value {
  text-align: center;
}

.compact .select-arrow {
  display: none;
}

.custom-select.is-error .select-trigger {
  border-color: #e74c3c;
  background: #fff5f5;
}

.compact.is-error .select-trigger {
  border-left-color: #f0b4b4;
  background: #fff0f0;
}

.select-value {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 26rpx;
  color: #111318;
  font-weight: 700;
}

.select-value.placeholder {
  color: #b1b6bc;
  font-weight: 400;
}

.select-arrow {
  flex: 0 0 auto;
  color: #8d939b;
  font-size: 22rpx;
}

.select-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 40;
  background: transparent;
}

.select-dropdown {
  position: absolute;
  left: 0;
  right: 0;
  top: calc(100% + 8rpx);
  z-index: 50;
  max-height: 360rpx;
  overflow-y: auto;
  padding: 8rpx;
  border: 1rpx solid #e5e8eb;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(17, 19, 24, 0.12);
  box-sizing: border-box;
}

.compact .select-dropdown {
  left: auto;
  right: 0;
  min-width: 112rpx;
}

.elevated-mask {
  z-index: 1350;
  background: rgba(17, 19, 24, 0.35);
}

.elevated-panel {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  bottom: auto;
  max-width: 560rpx;
  max-height: 52vh;
  margin: 0 auto;
  z-index: 1351;
  transform: translateY(-50%);
  box-shadow: 0 18rpx 48rpx rgba(17, 19, 24, 0.2);
}

.select-option {
  display: flex;
  align-items: center;
  min-height: 72rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  box-sizing: border-box;
}

.select-option-label {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #4b5563;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.3;
}

.select-option.active {
  background: #eef2ff;
}

.select-option.active .select-option-label {
  color: #111827;
}

.select-option:active {
  background: #f4f5f6;
}
