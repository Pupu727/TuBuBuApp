.loading-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(247, 248, 244, 0.78);
  box-sizing: border-box;
}

.loading-panel {
  width: 360rpx;
  min-height: 320rpx;
  padding: 42rpx 34rpx 36rpx;
  border: 1rpx solid rgba(17, 19, 24, 0.06);
  border-radius: 34rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 24rpx 70rpx rgba(17, 19, 24, 0.14);
  box-sizing: border-box;
}

.loading-mark {
  position: relative;
  width: 132rpx;
  height: 104rpx;
}

.loading-pack {
  position: absolute;
  left: 28rpx;
  top: 14rpx;
  width: 76rpx;
  height: 82rpx;
  border-radius: 24rpx 24rpx 18rpx 18rpx;
  background: #111318;
  box-shadow: inset 0 0 0 6rpx rgba(185, 255, 47, 0.18);
}

.loading-pack::before,
.loading-pack::after {
  content: '';
  position: absolute;
  top: 28rpx;
  width: 14rpx;
  height: 42rpx;
  border-radius: 12rpx;
  background: #b9ff2f;
}

.loading-pack::before {
  left: -9rpx;
}

.loading-pack::after {
  right: -9rpx;
}

.loading-dot {
  position: absolute;
  bottom: 0;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #b9ff2f;
  animation: loadingPulse 1s ease-in-out infinite;
}

.dot-one {
  left: 32rpx;
}

.dot-two {
  left: 58rpx;
  animation-delay: 0.12s;
}

.dot-three {
  left: 84rpx;
  animation-delay: 0.24s;
}

.loading-title,
.loading-text {
  display: block;
  max-width: 100%;
  min-width: 0;
  text-align: center;
}

.loading-title {
  margin-top: 24rpx;
  color: #111318;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
}

.loading-text {
  margin-top: 12rpx;
  color: #697386;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.35;
  white-space: normal;
}

@keyframes loadingPulse {
  0%,
  80%,
  100% {
    opacity: 0.35;
    transform: translateY(0);
  }

  40% {
    opacity: 1;
    transform: translateY(-8rpx);
  }
}

@media (max-width: 360px) {
  .loading-panel {
    width: 320rpx;
    min-height: 292rpx;
    padding: 36rpx 28rpx 32rpx;
  }

  .loading-title {
    font-size: 31rpx;
  }

  .loading-text {
    font-size: 23rpx;
  }
}
