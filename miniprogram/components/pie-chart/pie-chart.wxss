.pie-chart-wrap {
  width: 100%;
  margin-top: 24rpx;
}

.pie-body,
.pie-legend-row,
.legend-left {
  display: flex;
  align-items: center;
}

.pie-body {
  gap: 20rpx;
  min-width: 0;
}

.pie-stage {
  position: relative;
  flex: 0 0 auto;
}

.pie-image {
  display: block;
  position: relative;
  z-index: 1;
  opacity: 1;
  transform: scale(1);
  transition: opacity 0.22s ease, transform 0.22s ease;
}

.pie-stage.is-fading .pie-image {
  opacity: 0.45;
  transform: scale(0.985);
}

.pie-canvas-buffer {
  position: fixed;
  left: -9999px;
  top: -9999px;
  opacity: 0;
  pointer-events: none;
}

.pie-center {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform: translate(-50%, -50%);
  text-align: center;
  pointer-events: none;
  box-sizing: border-box;
}

.center-value {
  display: block;
  max-width: 100%;
  font-weight: 900;
  line-height: 1.08;
  color: #111318;
  white-space: nowrap;
}

.center-label-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 100%;
  margin-top: 6rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: #eef0f2;
  box-sizing: border-box;
}

.center-label {
  display: block;
  max-width: 100%;
  color: #8a9199;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
}

.pie-legend {
  flex: 1;
  min-width: 0;
}

.pie-legend-row {
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 12rpx;
  padding: 8rpx 10rpx;
  border-radius: 999rpx;
  min-width: 0;
}

.pie-legend-row:first-child {
  margin-top: 0;
}

.pie-legend-row.is-active {
  background: #f1f2f0;
  box-shadow: 0 4rpx 12rpx rgba(17, 19, 24, 0.06);
}

.pie-legend-row.is-active .legend-name {
  color: #111318;
  font-weight: 900;
}

.pie-legend-row.is-active .legend-dot {
  box-shadow: 0 0 0 6rpx rgba(128, 103, 216, 0.12);
}

.legend-left {
  flex: 1;
  gap: 8rpx;
  min-width: 0;
}

.legend-dot {
  flex: 0 0 16rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #5f6770;
  font-size: 23rpx;
  font-weight: 800;
}

.legend-percent {
  flex: 0 0 auto;
  color: #4c535b;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
}

.legend-weight {
  flex: 0 0 auto;
  color: #727a84;
  font-size: 22rpx;
  font-weight: 800;
  white-space: nowrap;
}

@media (max-width: 360px) {
  .pie-body {
    gap: 14rpx;
  }

  .pie-legend-row {
    gap: 6rpx;
    padding-left: 6rpx;
    padding-right: 6rpx;
  }

  .legend-name,
  .legend-percent,
  .legend-weight {
    font-size: 21rpx;
  }
}
