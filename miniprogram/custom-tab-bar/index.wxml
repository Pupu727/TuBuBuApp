<view class="tabbar-host">
  <view class="tabbar-shell">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tab-item {{item.activeClass}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <image
        class="tab-icon"
        src="{{item.currentIconPath}}"
        mode="aspectFit"
      />
      <text class="tab-label">{{item.text}}</text>
    </view>
  </view>
</view>
